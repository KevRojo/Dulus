# Dulus — environment template.
# Copy to .env and fill in only the providers you use.
#
#   cp .env.example .env
#   docker compose up -d

# ── API keys ──────────────────────────────────────────────────────────────
# Anthropic (Claude Opus/Sonnet/Haiku)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, GPT-5, o3, etc.)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# NVIDIA — 14 free models on build.nvidia.com
NVIDIA_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Alibaba Qwen
QWEN_API_KEY=

# Moonshot Kimi
KIMI_API_KEY=

# ── Optional local services ───────────────────────────────────────────────
# Point Dulus at a local Ollama container instead of the default localhost:11434
# OLLAMA_HOST=http://ollama:11434

# PAPI Webhook — recibe alertas de Phone Verification
PAPI_WEBHOOK=http://localhost:8000/webhook

# Dulus internal server port (override only if 5000 is taken)
DULUS_PORT=5000

# ── Docker host port mapping ──────────────────────────────────────────────
# Inside the container Dulus listens on 5000/5151. These vars control how
# those ports are exposed on your HOST. Defaults are shifted off 5000/5151
# so a Docker'd Dulus doesn't fight a native install on the same machine.
DULUS_WEB_PORT=5050
DULUS_IPC_PORT=5152
